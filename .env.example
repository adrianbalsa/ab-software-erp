# Copy to `.env` in repo root before `docker compose up --build`.
# Never commit `.env` with real credentials.

# ---------------------------
# Core backend configuration
# ---------------------------
ENVIRONMENT=production
WEB_CONCURRENCY=4
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-server-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Redis / ARQ queue (billing + VeriFactu jobs)
REDIS_URL=redis://redis:6379/0
# Optional: dedicated queue name. API enqueue and worker must match.
# ARQ_BILLING_QUEUE_NAME=arq:queue
# Optional HA with Redis Sentinel (managed Redis HA or self-hosted Sentinel).
# REDIS_SENTINEL_HOSTS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
# REDIS_SENTINEL_MASTER=mymaster
# REDIS_CONN_TIMEOUT_SECONDS=2
# REDIS_CONN_RETRIES=5
# REDIS_CONN_RETRY_DELAY_SECONDS=1
# REDIS_MAX_CONNECTIONS=50

# Auth / crypto
JWT_SECRET_KEY=replace-with-strong-random-secret
# env | railway | vault | aws | secretsmanager | mock (tests)
SECRET_MANAGER_BACKEND=env
# AWS Secrets Manager (JSON en SecretString; requiere IAM o credenciales en runtime)
# AWS_SECRETS_MANAGER_SECRET_ID=
# AWS_SECRETS_CACHE_TTL_SECONDS=120
# Vault KV v2 (solo si SECRET_MANAGER_BACKEND=vault y quieres API; si no, secretos por env)
# VAULT_ADDR=https://vault.example:8200
# VAULT_KV_PATH=scanner/production
# VAULT_KV_MOUNT=secret
# VAULT_TOKEN=
# VAULT_TOKEN_FILE=/var/run/secrets/vault-token
# VAULT_CACHE_TTL_SECONDS=120
# VAULT_NAMESPACE=
# VAULT_CA_CERT=
# VAULT_TLS_VERIFY=true
# VAULT_AUTH_METHOD=token
# kubernetes: VAULT_K8S_ROLE=  VAULT_K8S_JWT_PATH=
# approle: VAULT_APPROLE_ROLE_ID=  VAULT_APPROLE_SECRET_ID=  VAULT_APPROLE_SECRET_ID_FILE=
ENCRYPTION_KEY=replace-with-44-char-fernet-key
# Opcional: clave Fernet anterior durante rotación (multi-key decrypt)
# ENCRYPTION_KEY_PREVIOUS=

# AI providers (optional if feature not used)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# OCR tickets / gastos: visión LLM vía LiteLLM (OPENAI_API_KEY y/o GEMINI_API_KEY / GOOGLE_API_KEY arriba).
# Opcional: forzar modelo — ver backend/app/services/ocr_service.py
# OCR_VISION_MODEL=openai/gpt-4o
# OCR_GEMINI_MODEL=gemini/gemini-1.5-flash
# LITELLM_MODEL_OCR=
# LITELLM_EMBEDDING_MODEL=openai/text-embedding-3-small

# Utilidad scripts/force_sync_user_password.py (alternativa a --password en CLI)
# FORCE_SYNC_USER_PASSWORD=

# Google Maps Platform (backend: geocoding, rutas, matriz de distancias)
Maps_API_KEY=
# TTL compartido de geocoding/rutas (Redis + geo_cache), por defecto 30 días.
GEO_CACHE_TTL_SECONDS=2592000

# Divulgación coordinada (RFC 9116). En producción usar buzón real y monitorizado (MX/DKIM).
SECURITY_CONTACT_EMAIL=security@ablogistics-os.com

# Backups S3 (BCK-001; GitHub Actions secrets / entorno operativo, no runtime app)
# BACKUP_AWS_REGION=eu-west-1
# BACKUP_S3_BUCKET=ab-logistics-backups-eu
# BACKUP_S3_PREFIX=ab-logistics/daily
# Opcional para SSE-KMS; si vacío se usa SSE-S3 (AES256).
# BACKUP_S3_KMS_KEY_ID=
# Script legacy infra/backup_system.sh: AWS_S3_BUCKET + AWS_S3_REGION/AWS_REGION + AWS_S3_PREFIX.

# Observability
SENTRY_DSN=
# Muestreo de trazas Sentry (0.0–1.0). En prod el código usa 0.1 si no se define.
SENTRY_TRACES_SAMPLE_RATE=
# Versión o commit desplegado (Sentry release). Si vacío: RAILWAY_GIT_COMMIT_SHA / VERCEL_GIT_COMMIT_SHA.
APP_RELEASE=
# Webhook unificado para alertas operativas asincronas (Slack/Discord/Telegram).
# Uso:
# - Creditos <10%: WARNING
# - Certificado AEAT <15 dias: CRITICAL
# - Excepcion no controlada: CRITICAL
# - Smoke-test manual: POST /api/v1/admin/test-alert
ALERT_WEBHOOK_URL=
# Legacy/compatibilidad: alert_service historico.
DISCORD_WEBHOOK_URL=
# Alerta dedicada para caducidad de certificados mTLS (CERT-001). Si vacio, se usan ALERT_WEBHOOK_URL/DISCORD_WEBHOOK_URL.
# MTLS_CERT_EXPIRY_ALERT_WEBHOOK_URL=
# Buckets de rate limiting para endpoints de coste alto (clave por JWT empresa_id / usuario / IP).
AI_RATE_LIMIT=30 per minute
MAPS_RATE_LIMIT=120 per minute
OCR_RATE_LIMIT=20 per minute
# Límite HTTP global por tenant (JWT empresa_id). Overrides JSON: {"<empresa_uuid>":"300 per minute"}
# o lista uuid=limite,uuid2=limite (claves normalizadas a minúsculas).
TENANT_RATE_LIMIT_DEFAULT=200 per minute
# TENANT_RATE_LIMIT_OVERRIDES={"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa":"500 per minute"}

# AEAT VeriFactu mTLS (opcional; no guardar certificados ni passwords en el repo)
AEAT_VERIFACTU_ENABLED=false
AEAT_CLIENT_CERT_PATH=
AEAT_CLIENT_KEY_PATH=
AEAT_CLIENT_P12_PATH=
AEAT_CLIENT_P12_PASSWORD=
AEAT_CLIENT_KEY_PASSWORD=

# VeriFactu: hash génesis de cadena (obligatorio si se emite/valida cadena). Sin valor por defecto en código.
# Mapa JSON por empresa_id o NIF (recomendado multi-tenant). Claves NIF sin espacios, mayúsculas.
# VERIFACTU_GENESIS_HASHES={"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa":"<64 hex minúsculas>","B12345678":"<64 hex>"}
# Alternativa monotenant / pruebas: un solo hash global
# VERIFACTU_GENESIS_HASH=<64 hex>
# Mismo esquema en JSON de Vault KV / AWS Secrets Manager (ver docs/operations/GOLIVE_READINESS_CHECKLIST.md §1.2).

# ---------------------------
# Frontend build/runtime vars
# ---------------------------
# Default to Nginx reverse proxy path in this dockerized stack.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_API_BASE=/api
# Opcional: mailto del portal cliente (por defecto comercial@ablogistics-os.com)
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPS_API_KEY=
NEXT_PUBLIC_SENTRY_DSN=
# Opcional: misma idea que APP_RELEASE del backend (visible en bundle si se usa NEXT_PUBLIC_*).
NEXT_PUBLIC_APP_RELEASE=

# ---------------------------
# Email strategy (backend)
# ---------------------------
# Facturas: smtp | resend | auto (auto prioriza SMTP y fallback a Resend)
EMAIL_STRATEGY_INVOICE=resend
# Transaccional (reset/onboarding/welcome/esg): resend | smtp | auto (auto prioriza Resend)
EMAIL_STRATEGY_TRANSACTIONAL=resend
EMAIL_FROM_NAME=AB Logistics OS
EMAILS_FROM_EMAIL=comercial@ablogistics-os.com

# Playwright (frontend/tests): URL del Next en marcha; smoke portal cliente (tests/portal-cliente.spec.ts)
# PLAYWRIGHT_TEST_BASE_URL=http://127.0.0.1:3000
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
# E2E_PORTAL_CLIENTE_JWT=
# Alternativa al JWT: login formulario (usuario rol cliente)
# E2E_PORTAL_CLIENT_EMAIL=
# E2E_PORTAL_CLIENT_PASSWORD=
