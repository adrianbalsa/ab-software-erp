# Copy to `.env` in repo root before `docker compose up --build`.
# Never commit `.env` with real credentials.

# ---------------------------
# Core backend configuration
# ---------------------------
ENVIRONMENT=production
WEB_CONCURRENCY=4
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-server-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Auth / crypto
JWT_SECRET_KEY=replace-with-strong-random-secret
ENCRYPTION_KEY=replace-with-44-char-fernet-key

# AI providers (optional if feature not used)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Observability
SENTRY_DSN=
DISCORD_WEBHOOK_URL=

# ---------------------------
# Frontend build/runtime vars
# ---------------------------
# Default to Nginx reverse proxy path in this dockerized stack.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_API_BASE=/api
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPS_API_KEY=
NEXT_PUBLIC_SENTRY_DSN=
