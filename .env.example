# Copy to `.env` in repo root before `docker compose up --build`.
# Never commit `.env` with real credentials.

# ---------------------------
# Core backend configuration
# ---------------------------
ENVIRONMENT=production
WEB_CONCURRENCY=4
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-server-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Auth / crypto
JWT_SECRET_KEY=replace-with-strong-random-secret
# env | railway | vault | aws | secretsmanager | mock (tests)
SECRET_MANAGER_BACKEND=env
# AWS Secrets Manager (JSON en SecretString; requiere IAM o credenciales en runtime)
# AWS_SECRETS_MANAGER_SECRET_ID=
# AWS_SECRETS_CACHE_TTL_SECONDS=120
# Vault KV v2 (solo si SECRET_MANAGER_BACKEND=vault y quieres API; si no, secretos por env)
# VAULT_ADDR=https://vault.example:8200
# VAULT_KV_PATH=scanner/production
# VAULT_KV_MOUNT=secret
# VAULT_TOKEN=
# VAULT_TOKEN_FILE=/var/run/secrets/vault-token
# VAULT_CACHE_TTL_SECONDS=120
# VAULT_NAMESPACE=
# VAULT_CA_CERT=
# VAULT_TLS_VERIFY=true
# VAULT_AUTH_METHOD=token
# kubernetes: VAULT_K8S_ROLE=  VAULT_K8S_JWT_PATH=
# approle: VAULT_APPROLE_ROLE_ID=  VAULT_APPROLE_SECRET_ID=  VAULT_APPROLE_SECRET_ID_FILE=
ENCRYPTION_KEY=replace-with-44-char-fernet-key
# Opcional: clave Fernet anterior durante rotación (multi-key decrypt)
# ENCRYPTION_KEY_PREVIOUS=

# AI providers (optional if feature not used)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Azure Document Intelligence (OCR facturas / gastos)
# AZURE_ENDPOINT=
# AZURE_KEY=

# Utilidad scripts/force_sync_user_password.py (alternativa a --password en CLI)
# FORCE_SYNC_USER_PASSWORD=

# Google Maps Platform (backend: geocoding, rutas, matriz de distancias)
Maps_API_KEY=

# Divulgación coordinada (RFC 9116). En producción usar buzón real y monitorizado (MX/DKIM).
SECURITY_CONTACT_EMAIL=security@ablogistics-os.com

# Observability
SENTRY_DSN=
# Muestreo de trazas Sentry (0.0–1.0). En prod el código usa 0.1 si no se define.
SENTRY_TRACES_SAMPLE_RATE=
# Versión o commit desplegado (Sentry release). Si vacío: RAILWAY_GIT_COMMIT_SHA / VERCEL_GIT_COMMIT_SHA.
APP_RELEASE=
DISCORD_WEBHOOK_URL=

# ---------------------------
# Frontend build/runtime vars
# ---------------------------
# Default to Nginx reverse proxy path in this dockerized stack.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_API_BASE=/api
# Opcional: mailto del portal cliente (por defecto comercial@ablogistics.os)
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPS_API_KEY=
NEXT_PUBLIC_SENTRY_DSN=
# Opcional: misma idea que APP_RELEASE del backend (visible en bundle si se usa NEXT_PUBLIC_*).
NEXT_PUBLIC_APP_RELEASE=

# Playwright (frontend/tests): URL del Next en marcha; smoke portal cliente (tests/portal-cliente.spec.ts)
# PLAYWRIGHT_TEST_BASE_URL=http://127.0.0.1:3000
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
# E2E_PORTAL_CLIENTE_JWT=
# Alternativa al JWT: login formulario (usuario rol cliente)
# E2E_PORTAL_CLIENT_EMAIL=
# E2E_PORTAL_CLIENT_PASSWORD=
