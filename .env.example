# Copiar a `.env` en la raíz del repo para docker compose / desarrollo local.
# No commitear `.env` con secretos reales.

# --- Backend (FastAPI) ---
ENVIRONMENT=development
# Producción: DEBUG forzado a False en código. No establecer DEBUG=1 en producción.
# DEBUG=false
#
# Hosts permitidos en cabecera Host (API). En producción: obligatorio (coma-separado) o API_PUBLIC_HOST.
# ALLOWED_HOSTS=api.tu-dominio.com
# API_PUBLIC_HOST=api.tu-dominio.com
#
# CORS: dominios del frontend (HTTPS). En producción: OFFICIAL_FRONTEND_ORIGIN y/o CORS_ALLOW_ORIGINS.
# OFFICIAL_FRONTEND_ORIGIN=https://app.tu-dominio.com
# CORS_ALLOW_ORIGINS=https://app.tu-dominio.com
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=
JWT_SECRET_KEY=
SESSION_SECRET_KEY=
# Fernet (44 chars base64 url-safe) para cifrado PII en reposo:
# clave generada con `python generate_key.py`
PII_ENCRYPTION_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Opcional: Redis explícito (compose fuerza redis://redis:6379/0 en el servicio backend)
# REDIS_URL=

# --- Frontend (build args / runtime) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Docker Compose producción (docker-compose.prod.yml) ---
# FQDN que envía Cloudflare (Host); deben coincidir con rutas públicas del túnel.
# APP_DOMAIN=app.tu-dominio.com
# API_DOMAIN=api.tu-dominio.com
# Cloudflare Tunnel (perfil compose "cloudflare"): token desde Zero Trust → Tunnels
# CLOUDFLARE_TUNNEL_TOKEN=
# Caddy solo en loopback del VPS (puerto publicado hacia el host)
# CADDY_BIND=127.0.0.1
# CADDY_HTTP_PORT=8080
# Workers Gunicorn (backend Dockerfile.prod)
# WEB_CONCURRENCY=4
