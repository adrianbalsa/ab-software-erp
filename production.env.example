# =============================================================================
# AB Logistics OS - Production environment template
# =============================================================================
# Copy this file to `.env` and fill with real values.
# Never commit real secrets.
#
# CRITICAL for "Vampire Radar" (route intelligence + emissions + live maps):
#   1) SUPABASE_URL / SUPABASE_SERVICE_KEY / SUPABASE_ANON_KEY
#   2) JWT_SECRET_KEY / SESSION_SECRET_KEY
#   3) ENCRYPTION_KEY (and preferably PII_ENCRYPTION_KEY)
#   4) REDIS_URL
#   5) Maps_API_KEY (backend Google Maps Platform)
# If any of those are missing, core Radar flows degrade or fail.
#

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
ENVIRONMENT=production
PROJECT_NAME=AB Logistics OS API
DEBUG=false

# Divulgación coordinada (RFC 9116): /.well-known/security.txt y JSON de cumplimiento.
# Crear el buzón en el proveedor de correo del dominio público, registros MX/DKIM y monitorización (alertas).
SECURITY_CONTACT_EMAIL=security@ablogistics-os.com

# Public domains (used in compose/proxy/Host checks)
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
OFFICIAL_FRONTEND_ORIGIN=https://app.example.com
API_PUBLIC_HOST=api.example.com
ALLOWED_HOSTS=api.example.com
CORS_ALLOW_ORIGINS=https://app.example.com
# Optional (for previews)
# CORS_ALLOW_ORIGIN_REGEX=^https://[\\w.-]+\\.vercel\\.app$

# -----------------------------------------------------------------------------
# Supabase / Auth (CRITICAL)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=
# Legacy compatibility
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# JWT / Session / Cookies (CRITICAL)
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=
# Optional alias supported by backend
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_COOKIE_NAME=abl_refresh
ACCESS_TOKEN_COOKIE_NAME=abl_auth_token
REFRESH_REUSE_GRACE_SECONDS=8
SESSION_SECRET_KEY=
COOKIE_SECURE=true
COOKIE_DOMAIN=.example.com

# -----------------------------------------------------------------------------
# Database / Redis (CRITICAL: Redis required by healthcheck)
# -----------------------------------------------------------------------------
DATABASE_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_DATABASE=
POSTGRES_HOST=
POSTGRES_PORT=6432
SQLALCHEMY_DATABASE_DRIVER=postgresql+psycopg
REDIS_URL=redis://redis:6379/0

# Optional PgBouncer TCP health probe
PGBOUNCER_HEALTH_HOST=
PGBOUNCER_HEALTH_PORT=6432

# -----------------------------------------------------------------------------
# Encryption / data protection (CRITICAL)
# -----------------------------------------------------------------------------
# Secret manager: env (default) | railway | vault | aws | secretsmanager | mock (tests)
SECRET_MANAGER_BACKEND=env
# AWS_SECRETS_MANAGER_SECRET_ID=
# AWS_SECRETS_CACHE_TTL_SECONDS=120
# Vault KV v2 (opcional; requiere VAULT_ADDR + VAULT_KV_PATH + VAULT_TOKEN o VAULT_TOKEN_FILE)
# VAULT_ADDR=
# VAULT_KV_PATH=
# VAULT_KV_MOUNT=secret
# VAULT_TOKEN=
# VAULT_TOKEN_FILE=
# VAULT_CACHE_TTL_SECONDS=120
# VAULT_AUTH_METHOD=token
# VAULT_K8S_ROLE=
# VAULT_K8S_JWT_PATH=
# VAULT_APPROLE_ROLE_ID=
# VAULT_APPROLE_SECRET_ID=
# VAULT_APPROLE_SECRET_ID_FILE=
ENCRYPTION_KEY=
# Durante rotación: clave antigua para descifrar datos aún no re-cifrados
ENCRYPTION_KEY_PREVIOUS=
ENCRYPTION_SECRET_KEY=
BANK_TOKEN_ENCRYPTION_KEY=
PII_ENCRYPTION_KEY=
PII_ENCRYPTION_KEY_PREVIOUS=
# Alias documental Due Diligence (misma semántica que PII_ENCRYPTION_KEY*)
# FERNET_PII_KEY=
# FERNET_PII_KEY_PREVIOUS=
# Auditoría CLI de rotación (scripts/rotate_secrets.py)
# SECURITY_AUDIT_EMPRESA_ID=

# -----------------------------------------------------------------------------
# Maps / Fleet tracking (CRITICAL for Vampire Radar map/routing)
# -----------------------------------------------------------------------------
# Backend (Geocoding, Distance Matrix, Routes): única variable soportada.
Maps_API_KEY=
# Frontend (clave restringida por referrer; build-time)
NEXT_PUBLIC_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Frontend API wiring
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_BASE=
# Correo mostrado en enlaces «Contacto / soporte» del portal cliente (opcional; por defecto comercial@ablogistics.os)
NEXT_PUBLIC_SUPPORT_EMAIL=
INTERNAL_API_BASE_URL=http://backend:8000

# Optional frontend Supabase client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# AI / Advisor
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
AZURE_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_ENDPOINT=
AZURE_KEY=
LOGISADVISOR_MODEL=
ADVISOR_MODEL=
ADVISOR_LLM_MODEL=
ADVISOR_FALLBACK_MODEL=anthropic/claude-3-5-sonnet-20240620
ALLOW_DEBUG_USER_CHECK=0

# -----------------------------------------------------------------------------
# ESG / ECO factors (used in emissions and CO2 reporting)
# -----------------------------------------------------------------------------
ECO_KG_CO2_POR_LITRO_DIESEL=2.67
ECO_DIESEL_EUR_POR_LITRO_REF=1.55
ECO_TONELADAS_POR_BULTO=0.5
ECO_FACTOR_HUELLA_PORTE_KG_CO2_TKM=0.062
ESG_CO2_KG_PER_L_EURO6_REF=2.64
ESG_LONG_ROUTE_KM=350
ESG_EUROVI_EMISSIONS_BONUS_PCT=15

# -----------------------------------------------------------------------------
# Billing / Payments
# -----------------------------------------------------------------------------
# Stripe webhook (Dashboard → Developers → Webhooks): POST /api/v1/webhooks/stripe
# Eventos mínimos recomendados en el endpoint:
#   checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.paid
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PUBLIC_APP_URL=https://app.example.com
STRIPE_SUCCESS_URL=https://app.example.com/dashboard?checkout=success
STRIPE_CANCEL_URL=https://app.example.com/?checkout=cancel
STRIPE_PORTAL_RETURN_URL=https://app.example.com/dashboard?portal=return
PUBLIC_APP_URL=https://app.example.com

GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_ENV=sandbox
GOCARDLESS_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=no-reply@example.com

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.example.com/auth/oauth/google/callback

# -----------------------------------------------------------------------------
# AEAT VeriFactu
# -----------------------------------------------------------------------------
AEAT_VERIFACTU_ENABLED=false
AEAT_VERIFACTU_USE_PRODUCTION=false
AEAT_BLOQUEAR_PROD_EN_DESARROLLO=true
AEAT_VERIFACTU_SUBMIT_URL_TEST=
AEAT_VERIFACTU_SUBMIT_URL_PROD=
# Validación estricta del fragmento RegFactu contra SuministroLR.xsd (local en backend) antes del POST SOAP.
AEAT_VERIFACTU_XSD_VALIDATE_REQUEST=true
# Opcional: URL o ruta a copia del XSD; por defecto usa aeat_client_py/xsd/SuministroLR.xsd empaquetado.
AEAT_VERIFACTU_SUMINISTRO_LR_XSD_URL=
AEAT_CLIENT_CERT_PATH=
AEAT_CLIENT_KEY_PATH=
AEAT_CLIENT_P12_PATH=
AEAT_CLIENT_P12_PASSWORD=
AEAT_CLIENT_KEY_PASSWORD=
VERIFACTU_VALIDATION_BASE_URL=
VERIFACTU_SERIE_FACTURA=FAC
VERIFACTU_SERIE_RECTIFICATIVA=R

# -----------------------------------------------------------------------------
# Observability / Ops
# -----------------------------------------------------------------------------
SENTRY_DSN=
# Etiqueta de release en Sentry (semver o commit). Alternativa: variables SHA del PaaS.
APP_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_RELEASE=
ALERT_WEBHOOK_URL=
LOG_FILE_PATH=/app/logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_ACCESS_TO_STDOUT=1

# Docker/Gunicorn tuning
WEB_CONCURRENCY=4
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30

# Cloudflare Tunnel / Caddy
CLOUDFLARE_TUNNEL_TOKEN=
CADDY_BIND=127.0.0.1
CADDY_HTTP_PORT=8080
